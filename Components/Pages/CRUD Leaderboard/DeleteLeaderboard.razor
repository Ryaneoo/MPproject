@page "/deleteleaderboard/{id:int}"
@attribute [StreamRendering]
@using MP.Components.Data
@using MP.Components.Models
@using Microsoft.EntityFrameworkCore
@inject IDbContextFactory<MP.Components.Data.MPcontext> DbFactory
@inject NavigationManager NavigationManager
@inject MP.Components.Data.MPcontext context
@rendermode InteractiveServer
<PageTitle>Delete Game</PageTitle>
<container style="text-align:center; color:slategray; align-content: center;">
    <h1 style="color:red">Warning: This page should only be accessed if you are an approved admin</h1>

    <div>
        
        @if (leaderboard is null)
        {
            <h1 style="color:red; text-align:center;"><em>No leaderboard can be found.</em></h1>
        }
        else
        {
            <h1 style="margin-top:40px;">Delete</h1>
            @* Get details on the current leaderboard *@
            <h2>Are you sure you want to delete this?</h2>
            <br />
            <div style="margin-left:25px;">
                <dl class="row">
                    <dt class="col-sm-2" style="font-size:30px;">Leaderboard ID</dt>
                    <dd class="col-sm-10" style="font-size:30px;">@leaderboard.LeaderboardID</dd>
                </dl>
                <dl class="row">
                    <dt class="col-sm-2" style="font-size:30px;">Leaderboard Name</dt>
                    <dd class="col-sm-10" style="font-size:30px;">@leaderboard.LeaderboardName</dd>
                </dl>
                <dl class="row">
                    <dt class="col-sm-2" style="font-size:30px;">Leaderboard Link (Firebase)</dt>
                    <dd class="col-sm-10" style="font-size:30px;">@leaderboard.FirebaseUrl</dd>
                </dl>
                <EditForm method="post" Model="leaderboard" OnValidSubmit="DeleteBoard" FormName="delete" Enhance>
                    <button type="submit" class="btn btn-danger" disabled="@(leaderboard is null)">Delete</button> |
                    <a href="/leaderboard">Back to Leaderboard</a>
                </EditForm>
            </div>
        }
    </div>
</container>
@code {
    [Parameter]
    public int id { get; set; }
    LeaderboardConfig? leaderboard;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();


    }
    protected override void OnInitialized() //get lesson id
    {
        leaderboard = context.Boards.FirstOrDefault(x => x.LeaderboardID == id);
    }
    private async Task DeleteBoard() //remove lesson from database
    {
        using var context = DbFactory.CreateDbContext();
        context.Boards.Remove(leaderboard!);
        await context.SaveChangesAsync();
        NavigationManager.NavigateTo("/games");
    }
}
