@page "/addleaderboard"
@using Microsoft.EntityFrameworkCore
@using MP.Components.Data
@using MP.Components.Models
@using SixLabors.ImageSharp;
@using SixLabors.ImageSharp.Processing;
@using SixLabors.ImageSharp.PixelFormats;
@inject IDbContextFactory<MP.Components.Data.MPcontext> DbFactory
@inject NavigationManager NavigationManager
@rendermode InteractiveServer
@inject IJSRuntime JS

<PageTitle>Add Leaderboard</PageTitle>

<!-- ADDED padding-top: 100px HERE TO PUSH CONTENT DOWN BELOW THE NAV BAR -->
<div style="max-width: 1100px; margin: 0 auto; padding-top: 100px; padding-bottom: 40px;">
    <div style="text-align:center; color:white;">
        <h1 style="margin:0;color:black;">Add Leaderboard</h1>
        <p style="margin: 12px 0 28px 0; color:black;">
            Add a new leaderboard.
        </p>
    </div>

    <EditForm method="post" Model="Boards" OnValidSubmit="AddLeaderboards" FormName="create" Enhance>
        <DataAnnotationsValidator />
        <ValidationSummary class="text-danger" role="alert" />

        <div style="
            display:flex;
            justify-content:center;
            ">

            <!-- LEFT: Form Card -->
            <div style="
                background:#111;
                border-radius: 18px;
                padding: 22px;
                box-shadow: 0 8px 30px rgba(0,0,0,0.35);
                ">
                <h4 style="color:white; margin:0 0 12px 0;">Leaderboard Details</h4>

                <div class="mb-3">
                    <label for="leaderboardname" class="form-label" style="color:white;">Leaderboard Name</label>
                    <InputText id="leaderboardname" @bind-Value="Boards.LeaderboardName" class="form-control" />
                    <ValidationMessage For="() => Boards.LeaderboardName" class="text-danger" />
                </div>

                <div class="mb-3">
                    <label for="leaderboardlink" class="form-label" style="color:white;">Leaderboard URL (Firebase ; Add the full link, include https...)</label>
                    <InputText id="leaderboardlink" @bind-Value="Boards.FirebaseUrl" class="form-control" />
                    <ValidationMessage For="() => Boards.FirebaseUrl" class="text-danger" />
                </div>
                <div class="mb-3" hidden>
                    <label for="leaderboardid" class="form-label">Leaderboard ID</label>
                    <InputNumber id="leaderboardid" @bind-Value="Boards.LeaderboardID" class="form-control" />
                    <ValidationMessage For="() => Boards.LeaderboardID" class="text-danger" />
                </div>

                <div style="display:flex; gap: 12px; justify-content:flex-end; margin-top: 14px;">
                    <a href="/" class="btn btn-secondary" style="padding: 10px 18px; font-weight:600;">
                        Back
                    </a>

                    <button type="submit" class="btn btn-primary" style="padding: 10px 22px; font-weight:600;">
                        Create
                    </button>
                </div>
            </div>

        </div>
    </EditForm>
</div>
<script>
    function showAlert() {
        alert("Leaderboard added successfully");
    }
</script>

@code {
    private MP.Components.Models.LeaderboardConfig Boards { get; set; } = new();
    
    private MPcontext context = default!;
    private async Task AddLeaderboards() //adds leaderboard to database 
    {
     
            using var context = DbFactory.CreateDbContext();
            context.Boards.Add(Boards);
            await context.SaveChangesAsync();
            await JS.InvokeVoidAsync("showAlert");

    }
}
