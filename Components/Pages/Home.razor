@page "/"
<PageTitle>Home</PageTitle>

<style>
    /* Prevent default margins from causing unexpected white space */
    html, body {
        margin: 0;
        padding: 0;
        background-color: #121212; /* Dark background fallback */
    }

    .hero {
        width: 100%;
        /* Replaced flex: 1 with explicit viewport height minus navbar height */
        min-height: calc(100vh);
        box-sizing: border-box;
        padding: 60px 20px 40px; /* Added top padding to keep the large title safely below your navbar */

        display: flex;
        flex-direction: column;
        justify-content: center;
        align-items: center;
        text-align: center;
        background: linear-gradient(rgba(0,0,0,0.55), rgba(0,0,0,0.55)), url('Images/gif.gif');
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .hero-title {
        color: white;
        font-family: 'Bauhaus 93';
        font-size: 110px; /* Unchanged */
        margin: 0;
        line-height: 1; /* Added to keep title bounds tightly aligned and prevent top clipping */
        text-shadow: 3px 3px 10px rgba(0,0,0,0.6);
    }

    .hero-subtitle {
        color: white;
        font-family: 'Calisto MT';
        font-size: 40px;
        font-weight: normal;
        margin-top: 20px;
        margin-bottom: 10px;
    }

    .hero-text {
        color: white;
        font-family: 'Calisto MT';
        font-size: 22px;
        margin-top: 0;
        margin-bottom: 40px;
    }

    .button-group {
        display: flex;
        flex-direction: column;
        gap: 20px;
        align-items: center;
    }

    .home-btn {
        width: 280px;
        padding: 18px 0;
        background-color: #6FAE55;
        color: white;
        text-decoration: none;
        font-family: 'Calisto MT';
        font-size: 28px;
        font-weight: bold;
        border-radius: 12px;
        transition: all 0.25s ease;
        box-shadow: 0 6px 16px rgba(0,0,0,0.3);
    }

        .home-btn:hover {
            background-color: #5A9446;
            color: white;
            transform: translateY(-3px);
            text-decoration: none;
        }
</style>

<div class="hero">

    <h1 class="hero-title">
        Calculo
    </h1>

    <h2 class="hero-subtitle">
        Making Mathematics Fun &amp; Easy
    </h2>

    <p class="hero-text">
        Welcome! Choose an activity below to begin.
    </p>

    <div class="button-group">

        <a class="home-btn" href="/lessons">
            📚 Start Learning
        </a>

        <a class="home-btn" href="/games">
            🎮 Play Games
        </a>

    </div>
</div>